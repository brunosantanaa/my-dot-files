{
    "redhat.telemetry.enabled": false,
    "terminal.integrated.profiles.linux": {
        "zsh": {
            "path": "zsh"
        },
        "bash": {
            "path": "bash",
            "icon": "terminal-bash"
        },
        "fish": {
            "path": "fish"
        },
        "tmux": {
            "path": "tmux",
            "icon": "terminal-tmux"
        },
        "pwsh": {
            "path": "pwsh",
            "icon": "terminal-powershell"
        }
    },
    "terminal.integrated.fontFamily": "MesloLGS NF",
    "terminal.integrated.fontSize": 11,
    "[python]": {
        "editor.formatOnType": true
    },
    "platformio-ide.useDevelopmentPIOCore": true,
    "workbench.iconTheme": "material-icon-theme",
    "material-icon-theme.files.associations": {
        "platformio.ini": "../../icons/pio",
        "sdkconfig.*": "../../icons/esp",
        "Doxyfile": "Settings",
        "*.suppress": "Stryker"
    },
    "material-icon-theme.folders.associations": {
        "unittest": "Test",
        "platform": "Constant"
    },
    "cmake.configureOnOpen": false,
    "files.associations": {
        "*.defaults": "properties",
        "*.esp-wrover-kit": "properties"
    },
    "workbench.editorAssociations": {
        "*.pdf": "pdf.preview"
    },
    "diffEditor.ignoreTrimWhitespace": false,
    "workbench.colorTheme": "Dracula Theme",
    "nrf-connect.enableTelemetry": true,
    "cmake.showOptionsMovedNotification": false,
    "material-icon-theme.files.customClones": [],
    "cmake.pinnedCommands": [
        "workbench.action.tasks.configureTaskRunner",
        "workbench.action.tasks.runTask"
    ],
    "idf.showOnboardingOnInit": false,
    "idf.hasWalkthroughBeenShown": true,
    "editor.inlineSuggest.suppressSuggestions": true,
    "cody.suggestions.mode": "auto-edit",
    "docker.extension.enableComposeLanguageServer": false,
    "notebook.formatOnSave.enabled": true,
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": false,
        "scminput": false
    },
    "[cpp]": {
        "editor.defaultFormatter": "xaver.clang-format"
    },
    "[c]": {
        "editor.defaultFormatter": "xaver.clang-format"
    },
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.quickSuggestions": {
            "other": true,
            "comments": false,
            "strings": true
        },
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "github.copilot.nextEditSuggestions.enabled": true,
    "terminal.integrated.shellIntegration.enabled": true,
    "terminal.integrated.shellIntegration.decorationsEnabled": "both",
    "terminal.integrated.shellIntegration.showWelcome": false,
    "terminal.integrated.commandTimeout": 30000,
    "claudeCode.preferredLocation": "panel",
    "hediet.vscode-drawio.resizeImages": null,
    "editor.formatOnSave": true
}
